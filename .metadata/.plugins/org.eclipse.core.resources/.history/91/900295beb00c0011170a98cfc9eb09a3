package assessment1;

import java.util.Scanner;

public class Problem_1 {

	public static void main(String[] args) {
		// TODO Auto-generated method stub
		
		Scanner sc = new Scanner(System.in);
		
		System.out.println("Enter the Size of Array: ");
		int n=sc.nextInt();
		
		int a[]=new int[n];
		System.out.println("Enter the Array Elements: ");
		for(int i=0;i<n;i++)
		{
			a[i]=sc.nextInt();
		}
		
		for(int i=0;i<n;i++)
		{
			int temp=a[i];
			int sum=0;
			while(a[i]>9)
			{
				while(a[i]!=0)
				{
					sum+=a[i];
				}
				a[i]=sum;
			}
			if(a[i]==7)
			{
				System.out.println("First Price is to Token: "+temp);
			}
			else if(a[i]==5)
			{
				System.out.println("Second price is to Token: "+temp);
			}
			else if(a[i]==3)
			{
				System.out.println("third price is to Token: "+temp);
			}
		}
		
		
		

	}

}
